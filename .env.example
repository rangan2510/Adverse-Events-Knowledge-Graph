# kg_ae configuration - copy to .env and fill in your key.
# Do not commit real secrets.
#
# The knowledge graph contains only public reference data; the only secret
# needed for the OpenRouter (dev/demo) path is the OpenRouter API key.

# -----------------------------------------------------------------------------
# Secrets
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
# Optional: enables the scoped web-search (entity verification) tool.
TAVILY_API_KEY=

# -----------------------------------------------------------------------------
# LLM (single OpenAI-compatible endpoint)
# -----------------------------------------------------------------------------
# provider: "openrouter" (dev) or "local" (deployment, built later)
KG_AE_LLM_PROVIDER=openrouter
KG_AE_LLM_BASE_URL=https://openrouter.ai/api/v1
# Open-source, EU-friendly defaults:
#   mistralai/mistral-small-3.2-24b-instruct   (recommended)
#   google/gemma-3-27b-it                       (alt)
KG_AE_LLM_MODEL=mistralai/mistral-small-3.2-24b-instruct
KG_AE_LLM_TEMPERATURE=0.1
KG_AE_LLM_MAX_TOKENS=4096

# Self-consistency ensemble (1 = single agent)
KG_AE_AGENT_ENSEMBLE_SIZE=1
KG_AE_MAX_ITERATIONS=8

# -----------------------------------------------------------------------------
# Compliance / airgap (kept off for the OpenRouter path)
# -----------------------------------------------------------------------------
KG_AE_AIRGAPPED=false
KG_AE_ALLOW_WEB_SEARCH=true

# -----------------------------------------------------------------------------
# Data + logging
# -----------------------------------------------------------------------------
KG_AE_DATA_DIR=data
KG_AE_LOG_LEVEL=INFO
