# Keep the build context small and reproducible.
# Only src/ + data/silver/ + project metadata are needed to build the image;
# the JSON graph is generated inside the image by `kg-ae build-graph`.

.venv/
**/__pycache__/
**/*.pyc
.pytest_cache/
.ruff_cache/
.git/
.github/

# Large data we do NOT ship. The image uses the committed, max-compressed
# graph archive (data/graph/graph.7z) and extracts it inside the image, so the
# raw JSON and the upstream layers are not part of the build context.
data/raw/
data/bronze/
data/silver/
data/graph/*.json
data/graph/meta.json

# Local env (secrets are passed at run time via --env-file / -e)
.env

# Editor / OS noise
.vscode/
*.log
